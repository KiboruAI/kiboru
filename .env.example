# ─────────────────────────────────────────────────────
# KIBORU Agent Army — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your .env file to GitHub
# ─────────────────────────────────────────────────────

# ── CHOOSE YOUR AI MODEL ──────────────────────────────
# Uncomment ONE provider only. KIBORU works with any of these.

# Option 1: Anthropic Claude (recommended — best for complex tasks)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Option 2: OpenAI GPT
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# Option 3: Groq (fast & affordable)
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# Option 4: Google Gemini
# GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# Option 5: Ollama (free, runs locally on your VPS — no API cost)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Option 6: OpenRouter (access 100+ models with one key)
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# ── OPENCLAW GATEWAY ──────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=generate_a_random_token_here
OPENCLAW_BIND=0.0.0.0:3000

# ── TELEGRAM ──────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── EMAIL (optional) ──────────────────────────────────
# Used by Hermes (Comms agent) to send emails
EMAIL_PROVIDER=resend
EMAIL_API_KEY=your_email_api_key_here
EMAIL_FROM=kiboru@yourdomain.com

# ── SOLANA (optional) ─────────────────────────────────
# Used by Sol (On-chain agent) for wallet & token data
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ── GENERAL ───────────────────────────────────────────
NODE_ENV=production
TZ=UTC
