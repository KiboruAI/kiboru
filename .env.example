# ─────────────────────────────────────────
# KIBORU Agent Army — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────

# AI Model (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenClaw Gateway
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here
OPENCLAW_BIND=0.0.0.0:3000

# Telegram Bot (required for Telegram integration)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Email (optional — for Hermes/Comms agent)
EMAIL_PROVIDER=resend
EMAIL_API_KEY=your_resend_api_key_here
EMAIL_FROM=kiboru@yourdomain.com

# Solana RPC (optional — for Sol/On-chain agent)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
BIRDEYE_API_KEY=your_birdeye_api_key_here

# Security
OPENCLAW_SECRET=generate_a_random_secret_here

# Environment
NODE_ENV=production
TZ=Asia/Jakarta
